# ===================================
# ADAMJEE COMPUTERS - BACKEND CONFIG
# ===================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/adamjee-db?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=adamjee_super_secret_jwt_key_2026_change_in_production

# JWT Expiry
JWT_EXPIRE=7d

# OpenAI API Key for AI Chatbot (Phase 3)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Config (Nodemailer - for contact form & order notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=support@adamjeecomputers.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
